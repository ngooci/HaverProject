@model HaverProject.Models.NCR

@{
    ViewData["Title"] = "Create";
}

<h1>NCR - Create</h1>
<hr />

<form asp-action="Create">
     <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="container">
        <div class="row">
            <div class="col">
                <div class="form-group">
                    <label asp-for="NCRNumber" class="control-label fw-bolder">NCR Number</label>
                    <input asp-for="NCRNumber" class="form-control" />
                    <span asp-validation-for="NCRNumber" class="text-danger"></span>
                </div>
                <div class="form-group form-check">
                    <label class="form-check-label">
                        <input class="form-check-input" asp-for="SupplierOrRecInsp" /> @Html.DisplayNameFor(model => model.SupplierOrRecInsp)
                    </label>
                </div>
                <div class="form-group form-check">
                    <label class="form-check-label">
                        <input class="form-check-input" asp-for="WIP" /> @Html.DisplayNameFor(model => model.WIP)
                    </label>
                </div>
                <div class="form-group">
                    <label asp-for="QuantityReceived" class="control-label fw-bolder">Quantity Received</label>
                    <input asp-for="QuantityReceived" class="form-control" />
                    <span asp-validation-for="QuantityReceived" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="DescriptionItem" class="control-label fw-bolder">Item Description</label>
                    <input asp-for="DescriptionItem" class="form-control" />
                    <span asp-validation-for="DescriptionItem" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="RepresentativesName" class="control-label fw-bolder">Representatives Name</label>
                    <input asp-for="RepresentativesName" class="form-control" />
                    <span asp-validation-for="RepresentativesName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label class="control-label fw-bolder">Item Marked</label>
                    <div class="form-group form-check">
                        <label class="form-check-label">
                            <input class="form-check-input" asp-for="Yes" /> @Html.DisplayNameFor(model => model.Yes)
                        </label>
                    </div>
                    <div class="form-group form-check">
                        <label class="form-check-label">
                            <input class="form-check-input" asp-for="No" /> @Html.DisplayNameFor(model => model.No)
                        </label>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="form-group">
                    <label asp-for="PONumber" class="control-label fw-bolder">PO Number</label>
                    <input asp-for="PONumber" class="form-control" />
                    <span asp-validation-for="PONumber" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Supplier" class="control-label fw-bolder">Supplier</label>
                    <input asp-for="Supplier" class="form-control" />
                    <span asp-validation-for="Supplier" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="QuantityDefected" class="control-label fw-bolder">Quantity Defected</label>
                    <input asp-for="QuantityDefected" class="form-control" />
                    <span asp-validation-for="QuantityDefected" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="DescriptionDefect" class="control-label fw-bolder">Defect Description</label>
                    <input asp-for="DescriptionDefect" class="form-control" />
                    <span asp-validation-for="DescriptionDefect" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Date" class="control-label fw-bolder">Date</label>
                    <input asp-for="Date" class="form-control" />
                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>

        </div>
    </div>
</form>
<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
