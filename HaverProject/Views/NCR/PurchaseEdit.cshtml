@model HaverProject.Models.NCR


@{
    ViewData["Title"] = "PurchaseEdit";
}

<h1>PurchaseEdit</h1>

<h4>NCR</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="PurchaseEdit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ID" />

            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="ReturntoSupplier" /> @Html.DisplayNameFor(model => model.ReturntoSupplier)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="ReworkInHouse" /> @Html.DisplayNameFor(model => model.ReworkInHouse)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="ScrapinHouse" /> @Html.DisplayNameFor(model => model.ScrapinHouse)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="DeferforHBC" /> @Html.DisplayNameFor(model => model.DeferforHBC)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="PreliminaryDecision" class="control-label"></label>
                <input asp-for="PreliminaryDecision" class="form-control" />
                <span asp-validation-for="PreliminaryDecision" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="CARYes" /> @Html.DisplayNameFor(model => model.CARYes)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="CARNo" /> @Html.DisplayNameFor(model => model.CARNo)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="FollowupYes" /> @Html.DisplayNameFor(model => model.FollowupYes)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="FollowupNo" /> @Html.DisplayNameFor(model => model.FollowupNo)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="PurchaseDate" class="control-label"></label>
                <input asp-for="Date" class="form-control" type="date" asp-format="{0:yyyy-MM-dd}" />
                <span asp-validation-for="PurchaseDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OperatingManagerName" class="control-label"></label>
                <input asp-for="OperatingManagerName" class="form-control" />
                <span asp-validation-for="OperatingManagerName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>

        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}


